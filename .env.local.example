# BIST Doktoru - Environment Variables
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun

# ============================================================
# Collect API - BIST Hisse Senetleri
# https://collectapi.com/tr/api/economy/ekonomi-ve-finans-api
# Ücretsiz plan: 100 istek/gün
# ============================================================
COLLECT_API_KEY=your_collect_api_key_here

# ============================================================
# Binance API - Kripto Para Fiyatları
# Public API - API Key gerekmez (opsiyonel)
# https://binance-docs.github.io/apidocs/spot/en/
# ============================================================
# BINANCE_API_KEY=your_binance_api_key_here (opsiyonel)
# BINANCE_SECRET_KEY=your_binance_secret_here (opsiyonel)

# ============================================================
# TCMB API - Döviz Kurları
# Ücretsiz, API Key gerekmez
# https://www.tcmb.gov.tr/kurlar/today.xml
# ============================================================
# TCMB_API_URL=https://www.tcmb.gov.tr/kurlar/today.xml

# ============================================================
# Next.js
# ============================================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
